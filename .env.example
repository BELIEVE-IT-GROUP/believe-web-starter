# Payload CMS
NEXT_PUBLIC_PAYLOAD_URL=https://cms.believe-global.com

# Tenant
# Prefer slug. ID remains supported only as a legacy fallback.
NEXT_PUBLIC_TENANT_SLUG=clientex
# NEXT_PUBLIC_TENANT_ID=1

# Preview + ISR
# Same value must be configured in Vercel and the CMS Settings/webhook.
REVALIDATE_SECRET=change-me-revalidate-secret
PREVIEW_SECRET=change-me-preview-secret

# Forms
DEFAULT_CONTACT_EMAIL=hello@example.com
PLUNK_API_KEY=your-plunk-api-key
PLUNK_NEWSLETTER_LIST_ID=optional-list-id
