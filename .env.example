# Payload CMS
NEXT_PUBLIC_PAYLOAD_URL=https://cms.believe-global.com

# Tenant
# Prefer slug. ID remains supported only as a legacy fallback.
NEXT_PUBLIC_TENANT_SLUG=clientex
# NEXT_PUBLIC_TENANT_ID=1

# Preview + ISR
# Same value must be configured in Vercel and the CMS Settings/webhook.
REVALIDATE_SECRET=change-me-revalidate-secret
PREVIEW_SECRET=change-me-preview-secret

# Forms
DEFAULT_CONTACT_EMAIL=hello@example.com
PLUNK_PUBLIC_API_KEY=pk_xxxxx  # Dashboard: mailing.believe-global.com
PLUNK_NEWSLETTER_LIST_ID=optional-list-id

# Neurorealidad — captura de leads + envío del Capítulo 1
# USESEND_API_KEY: clave del panel de besend.believe-global.com
# CAPITULO1_PDF_URL: URL pública del PDF en R2 (ej: https://pub-xxx.r2.dev/neurorealidad/capitulo-1.pdf)
# PLUNK_CAPITULO_LIST_ID: ID de la lista de Plunk para leads del libro (opcional)
USESEND_API_KEY=your-usesend-api-key
CAPITULO1_PDF_URL=https://your-r2-bucket.r2.dev/neurorealidad/capitulo-1.pdf
# PLUNK_CAPITULO_LIST_ID=  # opcional, ID de lista específica
